<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_inherit_fe_hka_oci" model="ir.ui.view">
        <field name="name">product.template.form.inherit.fe_hka_oci</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_information']//group[1]" position="after">
                <group string="FE_ETS (Panamá)">
                    <field name="hka_cpbs_id" options="{'no_create': False}"/>
                    <field name="hka_unidad_medida_id" options="{'no_create': False}"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="product_category_form_inherit_fe_hka_oci" model="ir.ui.view">
        <field name="name">product.category.form.inherit.fe_hka_oci</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group" position="inside">
                <field name="hka_cpbs_id"/>
            </xpath>
        </field>
    </record>
</odoo>
