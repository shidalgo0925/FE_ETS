<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_inherit_fe_hka_oci" model="ir.ui.view">
        <field name="name">res.company.form.inherit.fe_hka_oci</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="FE_ETS (Panamá)" name="fe_hka_pa">
                    <group>
                        <group string="Conexión al servicio (PAC)">
                            <p class="text-muted small" colspan="2">Credenciales del proveedor autorizado de certificación para envío a DGI.</p>
                            <field name="hka_integration_mode" string="Modo integración"/>
                            <field name="hka_ambiente" string="Ambiente"/>
                            <field name="hka_usuario" string="Usuario"/>
                            <field name="hka_clave" string="Contraseña" password="True" force_save="1"/>
                            <field name="hka_backend_url" string="URL API ETS" invisible="hka_integration_mode != 'ets_api'"/>
                            <field name="hka_backend_token" string="Token API ETS" password="True" force_save="1" invisible="hka_integration_mode != 'ets_api'"/>
                            <field name="hka_backend_timeout" string="Timeout API ETS (s)" invisible="hka_integration_mode != 'ets_api'"/>
                            <field name="hka_auto_send" string="Enviar automáticamente a DGI" widget="boolean_toggle"/>
                        </group>
                        <group string="Datos fiscales">
                            <p class="text-muted small" colspan="2">Configure los datos fiscales del emisor</p>
                            <field name="hka_ruc" string="RUC"/>
                            <field name="hka_dv" string="DV"/>
                            <field name="hka_codigo_sucursal" string="Código Sucursal"/>
                            <field name="hka_tipo_sucursal" string="Tipo Sucursal"/>
                            <field name="hka_punto_facturacion" string="Punto de Facturación"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <button name="action_hka_test_connection" type="object" string="Probar Conexión" class="btn-secondary" icon="fa-plug" colspan="2"/>
                        </group>
                        <group>
                        </group>
                    </group>
                    <group>
                        <group string="Configuración de documentos">
                            <p class="text-muted small" colspan="2">Configure el formato de los documentos</p>
                            <field name="hka_formato_cafe" string="Formato CAFE"/>
                            <field name="hka_entrega_cafe" string="Entrega CAFE"/>
                        </group>
                        <group string="Licencia">
                            <p class="text-muted small" colspan="2">Validación comercial de licencia FE_ETS contra servidor ETS.</p>
                            <field name="hka_license_key" string="Codigo de licencia"/>
                            <field name="hka_license_server_url" string="URL servidor licencias"/>
                            <field name="hka_license_server_token" string="Token servidor licencias" password="True" force_save="1"/>
                            <field name="hka_license_status" string="Estado" widget="badge"
                                   decoration-success="hka_license_status == 'active'"
                                   decoration-warning="hka_license_status == 'grace'"
                                   decoration-danger="hka_license_status in ['expired','suspended','invalid']"/>
                            <field name="hka_license_message" string="Mensaje" readonly="1"/>
                            <field name="hka_license_expires_at" string="Expira" readonly="1"/>
                            <field name="hka_license_last_check" string="Última validación" readonly="1"/>
                            <field name="hka_license_grace_until" string="Gracia hasta" readonly="1"/>
                            <button name="action_hka_activate_license" type="object" string="Activar licencia" class="btn-primary" colspan="2"/>
                            <button name="action_hka_revalidate_license" type="object" string="Revalidar" class="btn-secondary" colspan="2"/>
                            <separator string="Licencia PAC / Folios (legacy)"/>
                            <field name="hka_numero_licencia" string="Número de Licencia PAC"/>
                            <field name="hka_folios_disponibles" string="Folios Disponibles" readonly="1"/>
                            <field name="hka_ultima_sincronizacion" string="Última Sincronización" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
